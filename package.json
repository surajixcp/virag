{
  "name": "api",
  "version": "1.0.0",
  "description": "Api - Viraag",
  "main": "./src/server.js",
  "scripts": {
    "start": "node ./src/server.js",
    "dev": "NODE_ENV=development nodemon",
    "prod": "NODE_ENV=production nodemon",
    "test": "jest --coverage",
    "watch": "jest --coverage --watchAll",
    "lint": "eslint ./src && eslint ./tests",
    "testOnly": "jest",
    "checkCodeQuality": "eslint ./src && eslint ./tests && jest --coverage"
  },
  "author": "Sazid",
  "license": "ISC",
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "coverageThreshold": {
      "global": {
        "branches": 100,
        "functions": 100,
        "lines": 100,
        "statements": -10
      }
    }
  },
  "dependencies": {
    "agora-access-token": "^2.0.4",
    "axios": "^0.27.2",
    "bcrypt": "^5.0.1",
    "body-parser": "^1.20.0",
    "cors": "^2.8.5",
    "dotenv": "^16.0.1",
    "ejs": "^3.1.10",
    "express": "^4.18.1",
    "express-useragent": "^1.0.15",
    "firebase-admin": "^13.0.2",
    "http-errors": "^2.0.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^8.5.1",
    "lodash": "^4.17.21",
    "moment": "^2.29.4",
    "moment-duration-format": "^2.3.2",
    "mongodb": "^4.12.1",
    "mongoose": "^6.5.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemon": "^3.1.3",
    "redis": "^4.3.1",
    "sharp": "^0.33.4",
    "socket.io": "^4.7.5",
    "winston": "^3.8.1"
  },
  "devDependencies": {
    "eslint": "^8.21.0",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-plugin-import": "^2.26.0",
    "jest": "^28.1.3",
    "supertest": "^6.2.4"
  }
}
